{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: TUI guess the mumber. Extensible.",
            "type": "debugpy",
            "request": "launch",
            "module": "src.tui-guess-the-number.guess",
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": [
                "--min",
                "1",
                "--max",
                "1023",
                "--player-a",
                "human",
                "--player-b",
                "human"
            ]
        }
    ]
}